# Copy to .env.local and fill in real values.

# Neon Postgres. Two URLs: pooled (DATABASE_URL, runtime) + direct (DIRECT_URL, migrations).
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Auth.js. AUTH_SECRET via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="generate-32-bytes-base64"
AUTH_GOOGLE_ID="from-google-cloud-console.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-from-google-cloud-console"

# Allowlist. Comma-separated, no spaces.
ALLOWED_EMAILS="you@example.com,partner@example.com"

# Cloudflare R2. Optional until M8b file-artifact support lands.
R2_ENABLED="false"
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
